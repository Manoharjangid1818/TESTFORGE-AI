# TESTFORGE AI Environment Variables
# Copy this file to .env and fill in your values

# Application
TESTFORGE_APP_NAME=TESTFORGE AI
TESTFORGE_VERSION=2.0.0
TESTFORGE_ENVIRONMENT=production

# Backend Configuration
TESTFORGE_PORT=5000
TESTFORGE_HOST=localhost
TESTFORGE_BACKEND_URL=http://localhost:5000

# Frontend Configuration
REACT_APP_API_BASE_URL=http://localhost:5000
REACT_APP_APP_NAME=TESTFORGE AI
REACT_APP_VERSION=2.0.0
REACT_APP_TAGLINE=Forge Quality. Automate Confidence.

# Feature Flags
TESTFORGE_ENABLE_ANALYTICS=false
TESTFORGE_ENABLE_LOGGING=true
TESTFORGE_DEBUG_MODE=false

# Playwright Configuration
TESTFORGE_PLAYWRIGHT_TIMEOUT=30000
TESTFORGE_PLAYWRIGHT_HEADLESS=true

# Export Configuration
TESTFORGE_EXPORT_PATH=./exports
TESTFORGE_REPORT_FORMAT=csv
