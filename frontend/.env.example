# TESTFORGE AI Frontend Environment Variables

# API Configuration
REACT_APP_API_BASE_URL=http://localhost:5000
REACT_APP_API_VERSION=v1

# Application Info
REACT_APP_APP_NAME=TESTFORGE AI
REACT_APP_VERSION=2.0.0
REACT_APP_TAGLINE=Forge Quality. Automate Confidence.

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_NOTIFICATIONS=true
REACT_APP_DEBUG_MODE=false

# UI Configuration
REACT_APP_ITEMS_PER_PAGE=10
REACT_APP_MAX_FILE_SIZE_MB=100

# Links
REACT_APP_DOCUMENTATION_URL=https://github.com/testforge-ai/docs
REACT_APP_SUPPORT_URL=https://github.com/testforge-ai/support
REACT_APP_FEEDBACK_URL=https://github.com/testforge-ai/feedback
